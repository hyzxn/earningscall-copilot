# --- Configuration Guide ---
# Rename this file to .env and fill in the actual values.

# --- AI Backend ---
# gemini: Google Gemini API 사용 / ollama: Ollama 로컬 모델 사용
ANALYZER_BACKEND=ollama

# --- API Credentials (gemini 백엔드 사용 시) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Model Settings ---
# Gemini 모델 선택
GEMINI_MODEL=gemma-4-26b-a4b-it

# Ollama 설정
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b

# Whisper 모델 선택: tiny / base / small / medium / large-v3
WHISPER_MODEL=small

# Whisper 실행 장치: cuda (GPU) / cpu
WHISPER_DEVICE=cuda

# --- App Settings ---
# AI 요약/지표 추출 주기 (초)
# 0: 자동 분석 비활성화 (수동 분석만 허용)
SUMMARY_INTERVAL_SEC=60

# 오디오 증폭 (1.0 = 원본, 2.0 = 2배, 3.0 = 3배)
AUDIO_GAIN=2.0

# 정밀도 선택
# float16 / bfloat16 / int8_float16
WHISPER_COMPUTE=float16
